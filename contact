<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact | Seaside Bliss Events</title>
  <meta name="description" content="Contact Seaside Bliss Events at Herne Bay Pier for weddings, celebrations and private events by the sea.">

  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Great+Vibes&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #FAF7F2; font-family: 'Lato', sans-serif; color: #1C2B3A; }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(28,43,58,0.97);
      border-bottom: 1px solid rgba(201,168,76,0.2);
      backdrop-filter: blur(8px);
    }

    .nav-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 8%;
      display: flex; align-items: center; justify-content: space-between; height: 72px;
    }

    .nav-logo { text-decoration: none; display: flex; flex-direction: column; gap: 1px; }
    .nav-logo-script { font-family: 'Great Vibes', cursive; color: #C9A84C; font-size: 1.5rem; line-height: 1; }
    .nav-logo-sub { font-family: 'Lato', sans-serif; color: #FAF7F2; font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; opacity: 0.8; }

    .nav-links { display: flex; gap: 2.5rem; align-items: center; }
    .nav-links a { font-family: 'Lato', sans-serif; color: #FAF7F2; text-decoration: none; font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase; transition: color 0.2s; }
    .nav-links a:hover { color: #C9A84C; }
    .nav-cta { background: #C9A84C; color: #1C2B3A !important; padding: 0.6rem 1.5rem; font-weight: 700 !important; transition: opacity 0.2s !important; }
    .nav-cta:hover { opacity: 0.85; color: #1C2B3A !important; }

    @media(max-width:768px){ .nav-links { display: none; } }

    .hero {
      position: relative; height: 55vh; min-height: 380px; overflow: hidden;
      display: flex; align-items: center; padding: 0 8%; padding-top: 72px;
      background: linear-gradient(135deg, #1C2B3A 0%, #2a3f52 60%, #1C2B3A 100%);
    }

    .hero-overlay {
      position: absolute; inset: 0;
      background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1600&q=80') center/cover no-repeat;
      opacity: 0.15;
    }

    .hero-content { position: relative; max-width: 600px; }
    .hero-script { font-family: 'Great Vibes', cursive; color: #C9A84C; font-size: clamp(1.5rem,3vw,2.2rem); margin-bottom: 0.5rem; }
    .hero-h1 { font-family: 'Cormorant Garamond', serif; color: #FAF7F2; font-size: clamp(2.2rem,5vw,3.8rem); font-weight: 600; line-height: 1.15; margin-bottom: 1rem; }
    .gold-bar { width: 60px; height: 2px; background: #C9A84C; margin: 1rem 0; }
    .hero-sub { color: #E8DDD0; font-size: 1.05rem; line-height: 1.8; font-weight: 300; }

    section { padding: 5rem 8%; }
    .section-inner { max-width: 1200px; margin: 0 auto; }
    .section-title { font-family: 'Cormorant Garamond', serif; color: #1C2B3A; font-size: clamp(1.8rem,3.5vw,2.8rem); font-weight: 600; }
    .section-script { font-family: 'Great Vibes', cursive; color: #C9A84C; font-size: 1.5rem; margin-bottom: 0.3rem; display: block; }
    .gold-bar-center { width: 60px; height: 2px; background: #C9A84C; margin: 1rem auto; }

    .find-us-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    @media(max-width:768px){ .find-us-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

    .info-card { display: flex; flex-direction: column; gap: 2rem; }
    .info-item { display: flex; gap: 1.2rem; align-items: flex-start; }

    .info-icon {
      width: 48px; height: 48px; flex-shrink: 0;
      background: #F5F0E8; border-top: 3px solid #C9A84C;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }

    .info-label { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: #C9A84C; font-weight: 700; margin-bottom: 0.3rem; }
    .info-value { color: #1C2B3A; font-size: 1rem; line-height: 1.6; font-weight: 400; }
    .info-value a { color: #1C2B3A; text-decoration: none; transition: color 0.2s; }
    .info-value a:hover { color: #C9A84C; }

    .map-container {
      border-top: 3px solid #C9A84C;
      overflow: hidden;
      box-shadow: 0 4px 30px rgba(28,43,58,0.1);
    }

    .map-container iframe { display: block; width: 100%; height: 340px; border: none; }

    .contact-section { background: #F5F0E8; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media(max-width:640px){ .form-grid { grid-template-columns: 1fr; } }

    .field { display: flex; flex-direction: column; gap: 0.4rem; }
    .field label { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: #888; font-weight: 700; }

    .field input,
    .field select,
    .field textarea {
      border: none;
      border-bottom: 1px solid #C9A84C;
      background: transparent;
      padding: 0.75rem 0;
      font-size: 1rem;
      color: #1C2B3A;
      outline: none;
      font-family: 'Lato', sans-serif;
      transition: border-color 0.2s;
    }

    .field input:focus,
    .field select:focus,
    .field textarea:focus { border-bottom-color: #1C2B3A; }

    .field select { cursor: pointer; }
    .field textarea { resize: none; }
    .field-full { grid-column: 1 / -1; }

    .privacy-consent {
      grid-column: 1 / -1;
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      font-size: 0.85rem;
      color: #555;
      line-height: 1.5;
    }

    .privacy-consent input {
      width: auto;
      margin-top: 0.25rem;
    }

    .submit-btn {
      margin-top: 0.5rem;
      background: #1C2B3A; color: #FAF7F2;
      padding: 1.1rem 2.8rem; border: none;
      cursor: pointer; font-size: 0.85rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      font-weight: 700; font-family: 'Lato', sans-serif;
      transition: background 0.2s;
    }

    .submit-btn:hover { background: #C9A84C; color: #1C2B3A; }

    .success-msg {
      display: none; background: #8FAF8F; color: #fff;
      padding: 1rem 1.5rem; margin-top: 1rem;
      font-size: 0.95rem; font-weight: 400;
    }

    .error-msg {
      display: none; background: #c0392b; color: #fff;
      padding: 1rem 1.5rem; margin-top: 1rem;
      font-size: 0.95rem;
    }

    footer { background: #111D27; padding: 3rem 8%; text-align: center; }
    .footer-script { font-family: 'Great Vibes', cursive; color: #C9A84C; font-size: 1.6rem; margin-bottom: 0.3rem; }
    .footer-tagline { color: #8FAF8F; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem; }
    .footer-links { display: flex; justify-content: center; gap: 2.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .footer-links a { color: #E8DDD0; text-decoration: none; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.7; transition: opacity 0.2s; }
    .footer-links a:hover { opacity: 1; }
    .footer-copy { color: #555; font-size: 0.75rem; }

    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.revealed { opacity: 1; transform: translateY(0); }
  </style>
</head>

<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <span class="nav-logo-script">Seaside Bliss</span>
      <span class="nav-logo-sub">Events</span>
    </a>

    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/weddings">Weddings</a>
      <a href="/celebrations">Celebrations</a>
      <a href="/contact.html" style="color: #c9a84c; border-bottom: 1px solid #C9A84C; padding-bottom: 2px;">Contact</a>
      <a href="/contact.html" class="nav-cta">Enquire</a>
    </div>
  </div>
</nav>

<div class="hero">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-script">We'd love to hear from you</p>
    <h1 class="hero-h1">Get in Touch</h1>
    <div class="gold-bar"></div>
    <p class="hero-sub">Tell us about your occasion and we'll get back to you within 24 hours. Every celebration starts with a conversation.</p>
  </div>
</div>

<section>
  <div class="section-inner">
    <div class="reveal" style="text-align: center; margin-bottom: 3.5rem;">
      <span class="section-script">Visit Us</span>
      <h2 class="section-title">How to Find Us</h2>
      <div class="gold-bar-center"></div>
      <p style="color: #666; font-weight: 300; line-height: 1.8; max-width: 520px; margin: 0 auto;">
        We're located right on Herne Bay Pier — one of the most iconic seafront settings in Kent.
      </p>
    </div>

    <div class="find-us-grid">
      <div class="info-card reveal">
        <div class="info-item">
          <div class="info-icon">📍</div>
          <div>
            <p class="info-label">Address</p>
            <p class="info-value">
              Seaside Bliss Events Hut<br>
              The Pier, Central Parade<br>
              Herne Bay<br>
              CT6 5JN
            </p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon">📱</div>
          <div>
            <p class="info-label">Mobile</p>
            <p class="info-value">
              <a href="tel:+447391173788">+44 7391 173 788</a>
            </p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon">✉️</div>
          <div>
            <p class="info-label">Email</p>
            <p class="info-value">
              <a href="mailto:rositsa.sheppard@gmail.com">rositsa.sheppard@gmail.com</a>
            </p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon">🕐</div>
          <div>
            <p class="info-label">Enquiries</p>
            <p class="info-value">We respond to all enquiries within 24 hours. Available 7 days a week.</p>
          </div>
        </div>
      </div>

      <div class="map-container reveal">
        <iframe
          title="Seaside Bliss Events location"
          src="https://www.google.com/maps?q=Herne%20Bay%20Pier%2C%20Central%20Parade%2C%20Herne%20Bay%2C%20CT6%205JN&output=embed"
          width="100%"
          height="340"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </div>
</section>

<section class="contact-section">
  <div class="section-inner" style="max-width: 740px;">
    <div class="reveal" style="text-align: center; margin-bottom: 3rem;">
      <span class="section-script">Start Planning</span>
      <h2 class="section-title">Send Us an Enquiry</h2>
      <div class="gold-bar-center"></div>
      <p style="color: #666; font-weight: 300; line-height: 1.8;">
        Tell us about your vision and we'll be in touch within 24 hours.
      </p>
    </div>

    <form id="enquiry-form" class="reveal" action="https://formspree.io/f/mkoyqyzb" method="POST">
      <div class="form-grid">
        <div class="field">
          <label for="name">Your Name</label>
          <input id="name" autocomplete="name" name="name" required type="text">
        </div>

        <div class="field">
          <label for="email">Email Address</label>
          <input id="email" autocomplete="email" name="email" required type="email">
        </div>

        <div class="field">
          <label for="phone">Phone Number</label>
          <input id="phone" autocomplete="tel" name="phone" type="tel">
        </div>

        <div class="field">
          <label for="event">Type of Event</label>
          <select id="event" name="event_type" required>
            <option disabled selected value="">Select an event type</option>
            <option value="Wedding">Wedding</option>
            <option value="Birthday Party Adult">Birthday Party - Adult</option>
            <option value="Kids Party">Kids' Party</option>
            <option value="Anniversary">Anniversary</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="field">
          <label for="date">Preferred Date</label>
          <input id="date" name="preferred_date" type="date">
        </div>

        <div class="field">
          <label for="guests">Approximate Guest Count</label>
          <input id="guests" min="1" name="guest_count" type="number" placeholder="e.g. 25">
        </div>

        <div class="field field-full">
          <label for="message">Tell Us More</label>
          <textarea id="message" name="message" rows="4" required placeholder="Your vision, theme, anything special you have in mind..."></textarea>
        </div>

        <label class="privacy-consent">
          <input type="checkbox" name="privacy_consent" required>
          <span>I agree for Seaside Bliss Events to contact me about my enquiry.</span>
        </label>
      </div>

      <input style="display: none;" name="_gotcha" type="text">

      <button class="submit-btn" type="submit">Send Enquiry</button>

      <div id="success-msg" class="success-msg">
        ✓ Thank you for your enquiry. We have received your message and will get back to you as soon as possible.
      </div>

      <div id="error-msg" class="error-msg">
        Something went wrong. Please email us directly at rositsa.sheppard@gmail.com
      </div>
    </form>
  </div>
</section>

<footer>
  <p class="footer-script">Seaside Bliss Events</p>
  <p class="footer-tagline">Bringing dreams to life</p>

  <div class="footer-links">
    <a href="/">Home</a>
    <a href="/weddings">Weddings</a>
    <a href="/celebrations">Celebrations</a>
    <a href="/contact.html">Contact</a>
  </div>

  <p class="footer-copy">© <span id="yr"></span> Seaside Bliss Events</p>
</footer>

<script>
  const yearElement = document.getElementById("yr");
  if (yearElement) {
    yearElement.textContent = new Date().getFullYear();
  }

  const form = document.getElementById("enquiry-form");
  const successMsg = document.getElementById("success-msg");
  const errorMsg = document.getElementById("error-msg");

  if (form) {
    form.addEventListener("submit", async function (event) {
      event.preventDefault();

      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: form.method,
          body: formData,
          headers: {
            "Accept": "application/json"
          }
        });

        if (response.ok) {
          form.reset();
          successMsg.style.display = "block";
          errorMsg.style.display = "none";
        } else {
          successMsg.style.display = "none";
          errorMsg.style.display = "block";
        }
      } catch (error) {
        successMsg.style.display = "none";
        errorMsg.style.display = "block";
      }
    });
  }

  const reveals = document.querySelectorAll(".reveal");

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("revealed");
      }
    });
  });

  reveals.forEach(item => revealObserver.observe(item));
</script>

</body>
</html>
